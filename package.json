{
  "name": "mantle-pulse",
  "version": "1.0.0",
  "description": "AI-powered Mantle smart money Telegram bot",
  "main": "dist/src/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "compile": "hardhat compile",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network mantle_testnet",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network mantle_mainnet"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "fastify": "^5.8.5",
    "grammy": "^1.26.0",
    "graphql-request": "^6.1.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "cross-env": "^7.0.3",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
